{
	"name": "kanban-complete-mover",
	"version": "1.0.0",
	"description": "Obsidian plugin: move a checked Kanban card to the Complete lane.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "node --test test/board.test.ts"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.4.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"moment": "^2.30.1",
		"obsidian": "^1.13.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1"
	},
	"allowScripts": {
		"esbuild@0.25.5": true
	}
}
